@{
    Layout = "_Layout";
    ViewBag.Title = "Sing";
    Int32 bottles = Convert.ToInt32(Context.Session.GetString("Bottles"));
}

<body>
    <input type="submit" onclick="location.href='@Url.Action("SongForm","Home")'" value="Play again" />
    
    @for (var i = bottles; i > -1; i--) {
        if (i > 2) {
            var bottle = i - 1;
            <p>@bottle green bottles hanging on the wall,
            <br>@bottle green bottles hanging on the wall,
            <br>And if one green bottle should accidentally fall,
            <br>There'll be @bottle green bottles hanging on the wall.
            <br></p>
        } else if (i == 2) {
            var bottle = i - 1;
            <p>@bottle green bottles hanging on the wall,
            <br>@bottle green bottles hanging on the wall,
            <br>And if one green bottle should accidentally fall,
            <br>There'll be @bottle green bottle hanging on the wall.
            <br></p>
        } else if (i == 1) {
            var bottle = i - 1;
            <p>@bottle green bottles hanging on the wall,
            <br>@bottle green bottles hanging on the wall,
            <br>And if one green bottle should accidentally fall,
            <br>There'll be no green bottles hanging on the wall.
            <br></p>
        }
    }
</body>